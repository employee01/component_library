[
  {
    "name": "theme_info",
    "theme_name": "House of Wolves",
    "theme_version": "0.1.0",
    "theme_author": "indffrnt.",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Studio settings",
    "settings": [
      {
        "type": "richtext",
        "id": "studio_address",
        "label": "Studio Address",
        "default": "<p><strong>82A Hope St,</strong><br>Geelong West VIC 3218</p>"
      }
    ]
  },
  {
    "name": "Socials",
    "settings": [
      {
        "type": "header",
        "content": "Socials"
      },
      {
        "type": "text",
        "id": "instagram",
        "label": "Instagram",
        "default": "Instagram"
      },
      {
        "type": "text",
        "id": "facebook",
        "label": "Facebook",
        "default": "Facebook"
      },
      {
        "type": "text",
        "id": "twitter",
        "label": "Twitter",
        "default": "Twitter"
      },
      {
        "type": "text",
        "id": "tiktok",
        "label": "Tiktok",
        "default": "Tiktok"
      }
    ]
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_display_font",
        "default": "inter_n4",
        "label": "t:general.display"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "bebas_neue_n4",
        "label": "t:general.heading"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "inter_n4",
        "label": "Body font"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "image_picker",
        "id": "global_logo",
        "label": "t:general.site_logo"
      },
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 10,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:settings_schema.colors.name",
    "settings": [
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          {
            "type": "color",
            "id": "background",
            "label": "t:settings_schema.colors.settings.background.label",
            "default": "#000000"
          },
          {
            "type": "color_background",
            "id": "background_gradient",
            "label": "t:settings_schema.colors.settings.background_gradient.label",
            "info": "t:settings_schema.colors.settings.background_gradient.info",
            "default": "linear-gradient(#000000, #111111)"
          },
          {
            "type": "color",
            "id": "text",
            "label": "t:settings_schema.colors.settings.text.label",
            "default": "#fafafa"
          },
          {
            "type": "color",
            "id": "button",
            "label": "t:settings_schema.colors.settings.button_background.label",
            "default": "#a1853f"
          },
          {
            "type": "color",
            "id": "button_label",
            "label": "t:settings_schema.colors.settings.button_label.label",
            "default": "#000000"
          },
          {
            "type": "color",
            "id": "secondary_button_label",
            "label": "t:settings_schema.colors.settings.secondary_button_label.label",
            "default": "#fafafa"
          },
          {
            "type": "color",
            "id": "shadow",
            "label": "t:settings_schema.colors.settings.shadow.label",
            "default": "#0a0a0a"
          }
        ],
        "role": {
          "text": "text",
          "background": {
            "solid": "background",
            "gradient": "background_gradient"
          },
          "links": "secondary_button_label",
          "icons": "text",
          "primary_button": "button",
          "on_primary_button": "button_label",
          "primary_button_border": "button",
          "secondary_button": "background",
          "on_secondary_button": "secondary_button_label",
          "secondary_button_border": "secondary_button_label"
        }
      }
    ]
  }
]
